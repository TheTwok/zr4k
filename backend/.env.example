# ZR4K Environment Variables Example

# Plain bot settings
# No APP_URL, certificate, or Mini App domain is required.
JWT_SECRET=super_secret_jwt_sign_key_change_me

# Database & Redis Settings
# PostgreSQL format: postgresql+asyncpg://<username>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/zr4k
REDIS_URL=redis://localhost:6379/0

# Telegram Client Bot Settings
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIJKlmNoPQRsTUVwxyZ

# Telegram MTProto Userbot Settings
# Get API_ID and API_HASH from https://my.telegram.org/
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=abcdef0123456789abcdef0123456789

# Groq AI Digest Settings
# Get API Key from https://console.groq.com/
GROQ_API_KEY=gsk_abc123xyz...

# Admin Telegram ID (for receiving dead session notifications)
ADMIN_USER_ID=987654321
